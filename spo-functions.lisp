(DEFINE T . T)

(DEFINE COMMENT . (QUOTE APPEND-TWO-LISTS-USING-ONLY-ATOM-CONS-CAR-CDR))
(DEFINE APPEND . (LAMBDA (X Y)
  (COND ((ATOM X) Y)
        (T (CONS (CAR X) (APPEND (CDR X) Y))))))

(DEFINE COMMENT . (QUOTE EQUAL-STRUCTURAL-EQUALITY-EQ-WORKS-ONLY-FOR-ATOMS))
(DEFINE EQUAL . (LAMBDA (X Y)
  (COND ((ATOM X)
         (COND ((ATOM Y) (EQ X Y))
               (T NIL)))
        ((ATOM Y) NIL)
        ((EQUAL (CAR X) (CAR Y)) (EQUAL (CDR X) (CDR Y)))
        (T NIL))))

(DEFINE COMMENT . (QUOTE ===PART-2-VARIABLE-PROTOCOL===))

(DEFINE COMMENT . (QUOTE A-QUERY-VARIABLE-IS-WRITTEN-AS-A-TWO-ELEMENT-LIST))
(DEFINE COMMENT . (QUOTE WHOSE-FIRST-ELEMENT-IS-THE-ATOM-QUESTION-MARK))
(DEFINE COMMENT . (QUOTE EXAMPLE-PATTERN-TRIPLE-?-PERSON-JOB-?-J))
(DEFINE COMMENT . (QUOTE THIS-AVOIDS-NEEDING-CHARACTER-INSPECTION))
(DEFINE COMMENT . (QUOTE WHICH-SECTORLISP-DOES-NOT-PROVIDE))

(DEFINE VARIABLEP . (LAMBDA (X)
  (COND ((ATOM X) NIL)
        ((EQ (CAR X) (QUOTE ?)) T)
        (T NIL))))

(DEFINE COMMENT . (QUOTE LOOKUP-FIND-VARIABLE-IN-BINDING-ALIST))
(DEFINE COMMENT . (QUOTE BINDINGS-FORM--A-P-DOT-BITDIDDLE-BEN-B-J-DOT-WIZARD))
(DEFINE COMMENT . (QUOTE RETURNS-THE-BINDING-PAIR-OR-NIL-IF-NOT-FOUND))
(DEFINE LOOKUP . (LAMBDA (VAR BINDS)
  (COND ((ATOM BINDS) NIL)
        ((EQUAL (CAR (CAR BINDS)) VAR) (CAR BINDS))
        (T (LOOKUP VAR (CDR BINDS))))))

(DEFINE COMMENT . (QUOTE ===PART-3-PATTERN-MATCHING===))

(DEFINE COMMENT . (QUOTE MATCH-PAT-AGAINST-DAT-WITH-CURRENT-BINDINGS))
(DEFINE COMMENT . (QUOTE RETURNS-EXTENDED-BINDINGS-OR-THE-ATOM-FAIL))
(DEFINE COMMENT . (QUOTE THREE-CASES---ATOM-VARIABLE-OR-CONS-CELL))
(DEFINE MATCH . (LAMBDA (PAT DAT BINDS)
  (COND
    ((EQ BINDS (QUOTE FAIL))
     (QUOTE FAIL))
    ((ATOM PAT)
     (COND ((ATOM DAT)
            (COND ((EQ PAT DAT) BINDS)
                  (T (QUOTE FAIL))))
           (T (QUOTE FAIL))))
    ((VARIABLEP PAT)
     ((LAMBDA (B)
        (COND (B (MATCH (CDR B) DAT BINDS))
              (T (CONS (CONS PAT DAT) BINDS))))
      (LOOKUP PAT BINDS)))
    ((ATOM DAT)
     (QUOTE FAIL))
    (T (MATCH (CDR PAT) (CDR DAT)
              (MATCH (CAR PAT) (CAR DAT) BINDS))))))

(DEFINE COMMENT . (QUOTE SUBS-WALK-TEMPLATE-REPLACING-VARIABLES-WITH-BOUND-VALUES))
(DEFINE SUBS . (LAMBDA (TMPL BINDS)
  (COND ((ATOM TMPL) TMPL)
        ((VARIABLEP TMPL)
         ((LAMBDA (B)
            (COND (B (CDR B))
                  (T TMPL)))
          (LOOKUP TMPL BINDS)))
        (T (CONS (SUBS (CAR TMPL) BINDS)
                 (SUBS (CDR TMPL) BINDS))))))

(DEFINE COMMENT . (QUOTE MAP-SUBS-INSTANTIATE-TEMPLATE-FOR-EACH-BINDING-SET))
(DEFINE MAP-SUBS . (LAMBDA (BIND-LIST TMPL)
  (COND ((ATOM BIND-LIST) NIL)
        (T (CONS (SUBS TMPL (CAR BIND-LIST))
                 (MAP-SUBS (CDR BIND-LIST) TMPL))))))

(DEFINE COMMENT . (QUOTE ===PART-4-QUERY-ENGINE===))

(DEFINE COMMENT . (QUOTE QUERY-SIMPLE-SCAN-EVERY-FACT-IN-DB-COLLECT-MATCHES))
(DEFINE COMMENT . (QUOTE USES-IMMEDIATE-LAMBDA-TO-BIND-B-AND-REST-IN-ONE-STEP))
(DEFINE QUERY-SIMPLE . (LAMBDA (PAT BINDS DB)
  (COND ((ATOM DB) NIL)
        (T ((LAMBDA (B REST)
               (COND ((EQ B (QUOTE FAIL)) REST)
                     (T (CONS B REST))))
             (MATCH PAT (CAR DB) BINDS)
             (QUERY-SIMPLE PAT BINDS (CDR DB)))))))

(DEFINE COMMENT . (QUOTE MAPQUERY-APPLY-QUERY-TO-EACH-BINDING-SET-THEN-APPEND))
(DEFINE COMMENT . (QUOTE THIS-IS-THE-MECHANISM-THAT-IMPLEMENTS-RELATIONAL-JOINS))
(DEFINE MAPQUERY . (LAMBDA (EXPR BIND-LIST DB)
  (COND ((ATOM BIND-LIST) NIL)
        (T (APPEND (QUERY EXPR (CAR BIND-LIST) DB)
                   (MAPQUERY EXPR (CDR BIND-LIST) DB))))))

(DEFINE COMMENT . (QUOTE QUERY-AND-THREAD-CONJUNCTS-THROUGH-BINDING-STREAM))
(DEFINE QUERY-AND . (LAMBDA (CONJUNCTS BIND-LIST DB)
  (COND ((ATOM CONJUNCTS) BIND-LIST)
        (T (QUERY-AND (CDR CONJUNCTS)
                      (MAPQUERY (CAR CONJUNCTS) BIND-LIST DB)
                      DB)))))

(DEFINE COMMENT . (QUOTE QUERY-OR-UNION-OF-ALL-DISJUNCT-RESULTS))
(DEFINE QUERY-OR . (LAMBDA (DISJUNCTS BINDS DB)
  (COND ((ATOM DISJUNCTS) NIL)
        (T (APPEND (QUERY (CAR DISJUNCTS) BINDS DB)
                   (QUERY-OR (CDR DISJUNCTS) BINDS DB))))))

(DEFINE COMMENT . (QUOTE QUERY-NOT-NEGATION-AS-FAILURE))
(DEFINE QUERY-NOT . (LAMBDA (EXPR BINDS DB)
  (COND ((QUERY EXPR BINDS DB) NIL)
        (T (CONS BINDS NIL)))))

(DEFINE COMMENT . (QUOTE QUERY-MAIN-DISPATCHER-DISPATCHES-ON-FIRST-SYMBOL))
(DEFINE COMMENT . (QUOTE AND-OR-NOT-ARE-COMBINATORS-ANYTHING-ELSE-IS-A-PATTERN))
(DEFINE QUERY . (LAMBDA (EXPR BINDS DB)
  (COND ((EQ (CAR EXPR) (QUOTE AND))
         (QUERY-AND (CDR EXPR) (CONS BINDS NIL) DB))
        ((EQ (CAR EXPR) (QUOTE OR))
         (QUERY-OR (CDR EXPR) BINDS DB))
        ((EQ (CAR EXPR) (QUOTE NOT))
         (QUERY-NOT (CAR (CDR EXPR)) BINDS DB))
        (T (QUERY-SIMPLE EXPR BINDS DB)))))

(DEFINE COMMENT . (QUOTE ANSWER-RUNS-EXPR-AGAINST-DB-AND-APPLIES-TMPL-TO-RESULTS))
(DEFINE COMMENT . (QUOTE DB-IS-A-ZERO-ARG-LAMBDA-CALLED-AS-DB-IN-QUERIES))
(DEFINE COMMENT . (QUOTE PASSING-DB-AS-AN-ARGUMENT-KEEPS-THE-ENGINE-REUSABLE))
(DEFINE COMMENT . (QUOTE WITH-ANY-DATABASE-NOT-JUST-MICROSHAFT))
(DEFINE ANSWER . (LAMBDA (EXPR TMPL DB)
  (MAP-SUBS (QUERY EXPR NIL DB) TMPL)))

(DEFINE COMMENT . (QUOTE ===PART-5-ENTITY-CONVERSION===))

(DEFINE COMMENT . (QUOTE MEMBER-EQUAL-TEST-IF-X-IS-IN-LST-USING-STRUCTURAL-EQUAL))
(DEFINE MEMBER-EQUAL . (LAMBDA (X LST)
  (COND ((ATOM LST) NIL)
        ((EQUAL X (CAR LST)) T)
        (T (MEMBER-EQUAL X (CDR LST))))))

(DEFINE COMMENT . (QUOTE UNIQUE-SUBJECTS-COLLECT-DISTINCT-SUBJECTS-FROM-TRIPLE-LIST))
(DEFINE COMMENT . (QUOTE RECURSES-TO-END-THEN-PREPENDS-SUBJECT-ONLY-IF-NOT-YET-SEEN))
(DEFINE UNIQUE-SUBJECTS . (LAMBDA (DB)
  (COND ((ATOM DB) NIL)
        (T ((LAMBDA (S REST)
              (COND ((MEMBER-EQUAL S REST) REST)
                    (T (CONS S REST))))
             (CAR (CDR (CAR DB)))
             (UNIQUE-SUBJECTS (CDR DB)))))))

(DEFINE COMMENT . (QUOTE PO-PAIRS-FOR-COLLECT-ALL-PRED-OBJ-PAIRS-FOR-ONE-SUBJECT))
(DEFINE COMMENT . (QUOTE RETURNS-A-LIST-OF-TWO-ELEMENT-LISTS-LIKE-P1-O1-P2-O2))
(DEFINE PO-PAIRS-FOR . (LAMBDA (SUBJ DB)
  (COND ((ATOM DB) NIL)
        ((EQUAL SUBJ (CAR (CDR (CAR DB))))
         (CONS (CONS (CAR (CDR (CDR (CAR DB))))
                     (CONS (CAR (CDR (CDR (CDR (CAR DB))))) NIL))
               (PO-PAIRS-FOR SUBJ (CDR DB))))
        (T (PO-PAIRS-FOR SUBJ (CDR DB))))))

(DEFINE COMMENT . (QUOTE BUILD-ENTITY-LIST-MAP-EACH-SUBJECT-TO-AN-ENTITY-RECORD))
(DEFINE BUILD-ENTITY-LIST . (LAMBDA (SUBJS DB)
  (COND ((ATOM SUBJS) NIL)
        (T (CONS (CONS (QUOTE ENTITY)
                       (CONS (CAR SUBJS) (PO-PAIRS-FOR (CAR SUBJS) DB)))
                 (BUILD-ENTITY-LIST (CDR SUBJS) DB))))))

(DEFINE COMMENT . (QUOTE TRIPLES-TO-ENTITIES-GROUP-FLAT-TRIPLE-LIST-BY-SUBJECT))
(DEFINE COMMENT . (QUOTE IN--TRIPLE-S-P1-O1--TRIPLE-S-P2-O2))
(DEFINE COMMENT . (QUOTE OUT--ENTITY-S--P1-O1---P2-O2))
(DEFINE TRIPLES-TO-ENTITIES . (LAMBDA (DB)
  (BUILD-ENTITY-LIST (UNIQUE-SUBJECTS DB) DB)))

(DEFINE COMMENT . (QUOTE EXPAND-PO-EXPAND-ONE-SUBJECT-AND-PO-PAIR-LIST-INTO-TRIPLES))
(DEFINE EXPAND-PO . (LAMBDA (SUBJ PO-PAIRS)
  (COND ((ATOM PO-PAIRS) NIL)
        (T (CONS (CONS (QUOTE TRIPLE)
                       (CONS SUBJ (CAR PO-PAIRS)))
                 (EXPAND-PO SUBJ (CDR PO-PAIRS)))))))

(DEFINE COMMENT . (QUOTE ENTITIES-TO-TRIPLES-FLATTEN-ENTITY-LIST-BACK-TO-TRIPLES))
(DEFINE COMMENT . (QUOTE IN--ENTITY-S--P1-O1---P2-O2))
(DEFINE COMMENT . (QUOTE OUT--TRIPLE-S-P1-O1--TRIPLE-S-P2-O2))
(DEFINE ENTITIES-TO-TRIPLES . (LAMBDA (ENTITIES)
  (COND ((ATOM ENTITIES) NIL)
        (T (APPEND (EXPAND-PO (CAR (CDR (CAR ENTITIES)))
                              (CDR (CDR (CAR ENTITIES))))
                   (ENTITIES-TO-TRIPLES (CDR ENTITIES)))))))
