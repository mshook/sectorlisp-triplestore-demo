(DEFINE VARIABLEP . (LAMBDA (X)
  (COND ((ATOM X) NIL)
        ((EQ (CAR X) (QUOTE ?)) T)
        (T NIL))))

(DEFINE COMMENT . (QUOTE LOOKUP-FIND-VARIABLE-IN-BINDING-ALIST))
(DEFINE COMMENT . (QUOTE BINDINGS-FORM--A-P-DOT-BITDIDDLE-BEN-B-J-DOT-WIZARD))
(DEFINE COMMENT . (QUOTE RETURNS-THE-BINDING-PAIR-OR-NIL-IF-NOT-FOUND))
(DEFINE LOOKUP . (LAMBDA (VAR BINDS)
  (COND ((ATOM BINDS) NIL)
        ((EQUAL (CAR (CAR BINDS)) VAR) (CAR BINDS))
        (T (LOOKUP VAR (CDR BINDS))))))

(DEFINE COMMENT . (QUOTE ===PART-3-PATTERN-MATCHING===))

(DEFINE COMMENT . (QUOTE MATCH-PAT-AGAINST-DAT-WITH-CURRENT-BINDINGS))
(DEFINE COMMENT . (QUOTE RETURNS-EXTENDED-BINDINGS-OR-THE-ATOM-FAIL))
(DEFINE COMMENT . (QUOTE THREE-CASES---ATOM-VARIABLE-OR-CONS-CELL))
(DEFINE MATCH . (LAMBDA (PAT DAT BINDS)
  (COND
    ((EQ BINDS (QUOTE FAIL))
     (QUOTE FAIL))
    ((ATOM PAT)
     (COND ((ATOM DAT)
            (COND ((EQ PAT DAT) BINDS)
                  (T (QUOTE FAIL))))
           (T (QUOTE FAIL))))
    ((VARIABLEP PAT)
     ((LAMBDA (B)
        (COND (B (MATCH (CDR B) DAT BINDS))
              (T (CONS (CONS PAT DAT) BINDS))))
      (LOOKUP PAT BINDS)))
    ((ATOM DAT)
     (QUOTE FAIL))
    (T (MATCH (CDR PAT) (CDR DAT)
              (MATCH (CAR PAT) (CAR DAT) BINDS))))))

(DEFINE COMMENT . (QUOTE SUBS-WALK-TEMPLATE-REPLACING-VARIABLES-WITH-BOUND-VALUES))
(DEFINE SUBS . (LAMBDA (TMPL BINDS)
  (COND ((ATOM TMPL) TMPL)
        ((VARIABLEP TMPL)
         ((LAMBDA (B)
            (COND (B (CDR B))
                  (T TMPL)))
          (LOOKUP TMPL BINDS)))
        (T (CONS (SUBS (CAR TMPL) BINDS)
                 (SUBS (CDR TMPL) BINDS))))))

(DEFINE COMMENT . (QUOTE MAP-SUBS-INSTANTIATE-TEMPLATE-FOR-EACH-BINDING-SET))
(DEFINE MAP-SUBS . (LAMBDA (BIND-LIST TMPL)
  (COND ((ATOM BIND-LIST) NIL)
        (T (CONS (SUBS TMPL (CAR BIND-LIST))
                 (MAP-SUBS (CDR BIND-LIST) TMPL))))))

(DEFINE COMMENT . (QUOTE ===PART-4-QUERY-ENGINE===))

(DEFINE COMMENT . (QUOTE QUERY-SIMPLE-SCAN-EVERY-FACT-IN-DB-COLLECT-MATCHES))
(DEFINE COMMENT . (QUOTE USES-IMMEDIATE-LAMBDA-TO-BIND-B-AND-REST-IN-ONE-STEP))
(DEFINE QUERY-SIMPLE . (LAMBDA (PAT BINDS DB)
  (COND ((ATOM DB) NIL)
        (T ((LAMBDA (B REST)
               (COND ((EQ B (QUOTE FAIL)) REST)
                     (T (CONS B REST))))
             (MATCH PAT (CAR DB) BINDS)
             (QUERY-SIMPLE PAT BINDS (CDR DB)))))))

(DEFINE COMMENT . (QUOTE MAPQUERY-APPLY-QUERY-TO-EACH-BINDING-SET-THEN-APPEND))
(DEFINE COMMENT . (QUOTE THIS-IS-THE-MECHANISM-THAT-IMPLEMENTS-RELATIONAL-JOINS))
(DEFINE MAPQUERY . (LAMBDA (EXPR BIND-LIST DB)
  (COND ((ATOM BIND-LIST) NIL)
        (T (APPEND (QUERY EXPR (CAR BIND-LIST) DB)
                   (MAPQUERY EXPR (CDR BIND-LIST) DB))))))

(DEFINE COMMENT . (QUOTE QUERY-AND-THREAD-CONJUNCTS-THROUGH-BINDING-STREAM))
(DEFINE QUERY-AND . (LAMBDA (CONJUNCTS BIND-LIST DB)
  (COND ((ATOM CONJUNCTS) BIND-LIST)
        (T (QUERY-AND (CDR CONJUNCTS)
                      (MAPQUERY (CAR CONJUNCTS) BIND-LIST DB)
                      DB)))))

(DEFINE COMMENT . (QUOTE QUERY-OR-UNION-OF-ALL-DISJUNCT-RESULTS))
(DEFINE QUERY-OR . (LAMBDA (DISJUNCTS BINDS DB)
  (COND ((ATOM DISJUNCTS) NIL)
        (T (APPEND (QUERY (CAR DISJUNCTS) BINDS DB)
                   (QUERY-OR (CDR DISJUNCTS) BINDS DB))))))

(DEFINE COMMENT . (QUOTE QUERY-NOT-NEGATION-AS-FAILURE))
(DEFINE QUERY-NOT . (LAMBDA (EXPR BINDS DB)
  (COND ((QUERY EXPR BINDS DB) NIL)
        (T (CONS BINDS NIL)))))

(DEFINE COMMENT . (QUOTE QUERY-MAIN-DISPATCHER-DISPATCHES-ON-FIRST-SYMBOL))
(DEFINE COMMENT . (QUOTE AND-OR-NOT-ARE-COMBINATORS-ANYTHING-ELSE-IS-A-PATTERN))
(DEFINE QUERY . (LAMBDA (EXPR BINDS DB)
  (COND ((EQ (CAR EXPR) (QUOTE AND))
         (QUERY-AND (CDR EXPR) (CONS BINDS NIL) DB))
        ((EQ (CAR EXPR) (QUOTE OR))
         (QUERY-OR (CDR EXPR) BINDS DB))
        ((EQ (CAR EXPR) (QUOTE NOT))
         (QUERY-NOT (CAR (CDR EXPR)) BINDS DB))
        (T (QUERY-SIMPLE EXPR BINDS DB)))))

